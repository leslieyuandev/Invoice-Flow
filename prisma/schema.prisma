generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required tables ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core domain ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  phone         String?

  companyName     String?
  companyAddress  String?
  companyEmail    String?
  companyPhone    String?
  companyWebsite  String?
  ssmNumber       String?
  logoUrl            String?
  proposalLogoUrl    String?
  watermarkUrl       String?

  defaultCurrency        String  @default("MYR")
  defaultTaxRate         Decimal @default(0) @db.Decimal(5, 2)
  defaultPaymentTerms    Int?    @default(30)
  defaultNotes           String? @db.Text
  defaultTerms           String? @db.Text
  proposalDefaultTerms   String? @db.Text
  invoiceNumberPrefix    String  @default("INV")
  showDueDate            Boolean @default(true)

  accounts          Account[]
  sessions          Session[]
  clients           Client[]
  invoices          Invoice[]
  quotations        Quotation[]
  lineItemTemplates LineItemTemplate[]
  proposals         Proposal[]
  canvaProjects     CanvaProject[]
  canvaAssets       CanvaAsset[]
  mapsJobs          MapsScrapeJob[]
  mapsPlaces        MapsPlace[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id     String @id @default(cuid())
  userId String

  name         String
  email        String?
  phone        String?
  company      String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?

  deletedAt DateTime?

  invoices   Invoice[]
  quotations Quotation[]
  proposals  Proposal[]
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, email])
  @@index([userId, deletedAt])
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Invoice {
  id       String @id @default(cuid())
  userId   String
  clientId String

  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  currency      String        @default("MYR")

  issueDate DateTime
  dueDate   DateTime

  // All monetary amounts stored in cents to avoid floating-point errors
  subtotal       Int
  taxRate        Decimal      @db.Decimal(5, 2)
  taxAmount      Int
  discountType   DiscountType?
  discountValue  Decimal?     @db.Decimal(10, 2)
  discountAmount Int?
  total          Int

  // Sender snapshot — copied from User at creation; historically immutable
  senderName       String
  senderEmail      String?
  senderAddress    String?
  senderPhone      String?
  senderSsmNumber  String?
  senderLogoUrl    String?

  // Client snapshot — denormalized for fast PDF rendering
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientCompany String?

  notes String? @db.Text
  terms String? @db.Text

  sentAt   DateTime?
  paidAt   DateTime?
  viewedAt DateTime?

  deletedAt DateTime?

  // Link to quotation this invoice was converted from
  quotationId String?    @unique
  quotation   Quotation? @relation(fields: [quotationId], references: [id])

  lineItems LineItem[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, deletedAt])
  @@index([clientId])
}

model LineItem {
  id        String @id @default(cuid())
  invoiceId String

  sortOrder   Int     @default(0)
  description String
  notes       String? @db.Text
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Int
  amount      Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId, sortOrder])
}

// ─── Quotation ───────────────────────────────────────────────────────────────

model Quotation {
  id      String @id @default(cuid())
  userId  String
  clientId String

  quotationNumber String
  status          QuotationStatus @default(DRAFT)
  currency        String          @default("MYR")

  issueDate  DateTime
  expiryDate DateTime

  subtotal       Int
  taxRate        Decimal       @db.Decimal(5, 2)
  taxAmount      Int
  discountType   DiscountType?
  discountValue  Decimal?      @db.Decimal(10, 2)
  discountAmount Int?
  total          Int

  senderName      String
  senderEmail     String?
  senderAddress   String?
  senderPhone     String?
  senderSsmNumber String?
  senderLogoUrl   String?

  clientName    String
  clientEmail   String?
  clientAddress String?
  clientCompany String?

  notes String? @db.Text

  sentAt    DateTime?
  deletedAt DateTime?

  lineItems QuotationLineItem[]
  invoice   Invoice?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, quotationNumber])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, deletedAt])
  @@index([clientId])
}

model QuotationLineItem {
  id          String @id @default(cuid())
  quotationId String

  sortOrder   Int     @default(0)
  description String
  notes       String? @db.Text
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Int
  amount      Int

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quotationId, sortOrder])
}

// ─── Proposal Catalog ─────────────────────────────────────────────────────────

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model EventCategory {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  parentId  String?
  sortOrder Int     @default(0)

  parent   EventCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children EventCategory[] @relation("CategoryTree")
  packages CatalogPackage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model CatalogPackage {
  id            String  @id @default(cuid())
  categoryId    String
  name          String
  tagline       String?
  price         Int
  originalPrice Int?
  imageUrl      String?
  isBestSeller  Boolean @default(false)
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  features CatalogPackageFeature[]
  category EventCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model CatalogPackageFeature {
  id        String @id @default(cuid())
  packageId String
  text      String
  sortOrder Int    @default(0)

  package CatalogPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, sortOrder])
}

model CatalogAddOn {
  id         String  @id @default(cuid())
  name       String
  price      Int?
  priceLabel String?
  unit       String?
  imageUrl   String?
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proposal {
  id     String @id @default(cuid())
  userId String

  leadName    String
  leadEmail   String?
  leadPhone   String?
  clientId    String?

  senderName    String
  senderEmail   String?
  senderLogoUrl String?
  senderPhone   String?

  eventTitle      String
  eventCategoryId String
  coverImageUrl   String?
  termsText       String? @db.Text

  status    ProposalStatus @default(DRAFT)
  sentAt    DateTime?
  deletedAt DateTime?

  bgColor       String?
  coverTitle    String?
  addOnsEnabled Boolean @default(false)
  compact       Boolean @default(false)

  items  ProposalItem[]
  addOns ProposalAddOnItem[]

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, deletedAt])
}

model ProposalItem {
  id         String @id @default(cuid())
  proposalId String
  sortOrder  Int    @default(0)

  packageName   String
  tagline       String?
  price         Int
  originalPrice Int?
  imageUrl      String?
  isBestSeller  Boolean @default(false)
  features      String  @db.Text

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, sortOrder])
}

model ProposalAddOnItem {
  id         String @id @default(cuid())
  proposalId String
  sortOrder  Int    @default(0)

  addOnName  String
  price      Int?
  priceLabel String?
  imageUrl   String?
  quantity   Int    @default(1)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, sortOrder])
}

// ─── Canva Project (design editor) ───────────────────────────────────────────

model CanvaProject {
  id     String @id @default(cuid())
  userId String

  title  String @default("Untitled Design")
  format String @default("custom")
  width  Int
  height Int
  pages  Json   // [{ id, background, elements: [...] }]

  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
}

model CanvaAsset {
  id     String @id @default(cuid())
  userId String

  type   String // "image" | "font"
  url    String
  name   String @default("") // image: filename · font: family name
  meta   String @default("") // font: format (woff2/ttf/otf)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

// ─── Invoice Templates ────────────────────────────────────────────────────────

model LineItemTemplate {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String  @default("")
  unitPrice   Int     // stored in cents

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Google Maps Extractor ───────────────────────────────────────────────────

enum MapsJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model MapsScrapeJob {
  id     String        @id @default(cuid())
  userId String
  status MapsJobStatus @default(PENDING)

  searchQueries Json   // string[]
  coordinates   Json?  // { north, south, east, west } | null
  maxResults    Int    @default(50)
  language      String @default("en")
  proxyConfig   Json?  // { enabled, server, username } — password is never persisted
  config        Json?  // sanitized add-ons / filters / geolocation / start-urls / pre-opening

  requestedCount Int     @default(0) // searchQueries.length * maxResults (upper bound)
  resultCount    Int     @default(0)
  error          String? @db.Text

  startedAt  DateTime?
  finishedAt DateTime?

  places MapsPlace[]
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model MapsPlace {
  id     String @id @default(cuid())
  jobId  String
  userId String

  searchQuery String // which query produced this row
  placeId     String // Google place_id / ftid (unique identifier)

  title       String
  category    String?
  address     String?
  // Parsed address components for the Apify-style table columns
  street      String?
  city        String?
  state       String?
  countryCode String?

  latitude  Float?
  longitude Float?

  phone         String?
  website       String?
  claimedStatus String?

  operatingHours Json? // string[] | { day: hours }

  rating        Float?
  reviewCount   Int?
  openingStatus String? // "Opening Soon" / "Newly Opened" / "Open" / "Closed" / ...

  // ── Add-on / detail-crawl fields (populated only when those add-ons run) ──
  isClaimed      Boolean? // null = unknown (list-only run); false = "Claim this business" shown
  description    String?  @db.Text
  plusCode       String?
  priceLevel     String?
  imageUrls      Json?    // string[]
  reviews        Json?    // [{ author, rating, text, date }]
  emails         Json?    // string[] (scraped from the business website)
  socialProfiles Json?    // { facebook, instagram, linkedin, twitter, tiktok, youtube }

  // ── Pre-opening / newly-opened lead detection ──
  isLikelyNew    Boolean @default(false)
  newnessSignals Json?   // { zeroReviews, unclaimed, tempWords, openingSoon }

  job  MapsScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([jobId, placeId]) // dedupe within a job
  @@index([jobId])
  @@index([userId])
  @@index([jobId, isLikelyNew])
}
