generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required tables ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core domain ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  phone         String?

  companyName     String?
  companyAddress  String?
  companyEmail    String?
  companyPhone    String?
  companyWebsite  String?
  logoUrl         String?

  defaultCurrency        String  @default("MYR")
  defaultTaxRate         Decimal @default(0) @db.Decimal(5, 2)
  defaultPaymentTerms    Int?    @default(30)
  defaultNotes           String? @db.Text
  defaultTerms           String? @db.Text
  invoiceNumberPrefix    String  @default("INV")
  showDueDate            Boolean @default(true)

  accounts          Account[]
  sessions          Session[]
  clients           Client[]
  invoices          Invoice[]
  lineItemTemplates LineItemTemplate[]
  proposals         Proposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id     String @id @default(cuid())
  userId String

  name         String
  email        String?
  phone        String?
  company      String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?

  deletedAt DateTime?

  invoices  Invoice[]
  proposals Proposal[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, email])
  @@index([userId, deletedAt])
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Invoice {
  id       String @id @default(cuid())
  userId   String
  clientId String

  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  currency      String        @default("MYR")

  issueDate DateTime
  dueDate   DateTime

  // All monetary amounts stored in cents to avoid floating-point errors
  subtotal       Int
  taxRate        Decimal      @db.Decimal(5, 2)
  taxAmount      Int
  discountType   DiscountType?
  discountValue  Decimal?     @db.Decimal(10, 2)
  discountAmount Int?
  total          Int

  // Sender snapshot — copied from User at creation; historically immutable
  senderName    String
  senderEmail   String?
  senderAddress String?
  senderPhone   String?
  senderLogoUrl String?

  // Client snapshot — denormalized for fast PDF rendering
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientCompany String?

  notes String? @db.Text
  terms String? @db.Text

  sentAt   DateTime?
  paidAt   DateTime?
  viewedAt DateTime?

  deletedAt DateTime?

  lineItems LineItem[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, deletedAt])
  @@index([clientId])
}

model LineItem {
  id        String @id @default(cuid())
  invoiceId String

  sortOrder   Int     @default(0)
  description String
  notes       String? @db.Text
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Int
  amount      Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId, sortOrder])
}

// ─── Proposal Catalog ─────────────────────────────────────────────────────────

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model EventCategory {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  parentId  String?
  sortOrder Int     @default(0)

  parent   EventCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children EventCategory[] @relation("CategoryTree")
  packages CatalogPackage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model CatalogPackage {
  id            String  @id @default(cuid())
  categoryId    String
  name          String
  tagline       String?
  price         Int
  originalPrice Int?
  imageUrl      String?
  isBestSeller  Boolean @default(false)
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  features CatalogPackageFeature[]
  category EventCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model CatalogPackageFeature {
  id        String @id @default(cuid())
  packageId String
  text      String
  sortOrder Int    @default(0)

  package CatalogPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, sortOrder])
}

model CatalogAddOn {
  id         String  @id @default(cuid())
  name       String
  price      Int?
  priceLabel String?
  unit       String?
  imageUrl   String?
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proposal {
  id     String @id @default(cuid())
  userId String

  leadName    String
  leadEmail   String?
  leadPhone   String?
  clientId    String?

  senderName    String
  senderEmail   String?
  senderLogoUrl String?
  senderPhone   String?

  eventTitle      String
  eventCategoryId String
  coverImageUrl   String?
  termsText       String? @db.Text

  status    ProposalStatus @default(DRAFT)
  sentAt    DateTime?
  deletedAt DateTime?

  bgColor       String?
  coverTitle    String?
  pagesCount    Int     @default(1)
  addOnsEnabled Boolean @default(false)
  creativity    Int     @default(50)
  elegance      Int     @default(50)

  items  ProposalItem[]
  addOns ProposalAddOnItem[]

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, deletedAt])
}

model ProposalItem {
  id         String @id @default(cuid())
  proposalId String
  sortOrder  Int    @default(0)

  packageName   String
  tagline       String?
  price         Int
  originalPrice Int?
  imageUrl      String?
  isBestSeller  Boolean @default(false)
  features      String  @db.Text

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, sortOrder])
}

model ProposalAddOnItem {
  id         String @id @default(cuid())
  proposalId String
  sortOrder  Int    @default(0)

  addOnName  String
  price      Int?
  priceLabel String?
  imageUrl   String?
  quantity   Int    @default(1)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, sortOrder])
}

// ─── Invoice Templates ────────────────────────────────────────────────────────

model LineItemTemplate {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String  @default("")
  unitPrice   Int     // stored in cents

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
